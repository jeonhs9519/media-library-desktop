{
  "name": "media-library-desktop",
  "version": "0.0.4",
  "description": "Personal Media Library Desktop App",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "icon:build": "node ./scripts/build-icon.js",
    "release:patch": "node ./scripts/release.js",
    "bundle:main": "esbuild src/main/index.ts --bundle --platform=node --target=node22 --outfile=out/main/index.js --external:electron --external:sharp --external:better-sqlite3",
    "package:win": "electron-builder --win zip",
    "preview": "electron-vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "react-virtuoso": "^4.18.1",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "to-ico": "^1.1.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "esbuild": "^0.18.19"
  }
  ,
  "build": {
    "productName": "MediaLibrary",
    "artifactName": "MediaLibrary_v${version}.${ext}",
    "win": {
      "icon": "build/icon.ico"
    },
    "asar": true,
    "compression": "maximum",
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/@napi-rs/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "afterPack": "./scripts/after-pack.js",
    "extraResources": [
      {
        "from": "src/main/db/migrations",
        "to": "migrations"
      }
    ],
    "files": [
      "out/**",
      "package.json",
      "!**/*.map",
      "!tests/**",
      "!**/*.md",
      "!**/test/**",
      "!**/.github/**",
      "!**/.vscode/**"
    ]
  }
}